# Slack app credentials (from your app's Basic Information / OAuth / Socket Mode pages)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Team id used by get_team_aggregate_wellbeing (Slack workspace/team id, e.g. T0123ABC)
SLACK_TEAM_ID=

# Detection thresholds (see src/config.ts for defaults if unset)
PACE_MIN_EVENTS=10
PACE_WINDOW_MINUTES=180
PACE_MAX_GAP_MINUTES=4
PACE_NUDGE_COOLDOWN_MINUTES=240
