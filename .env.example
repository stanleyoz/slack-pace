# Slack app credentials (from your app's Basic Information / OAuth / Socket Mode pages)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Team id used by get_team_aggregate_wellbeing (Slack workspace/team id, e.g. T0123ABC)
SLACK_TEAM_ID=

# Detection thresholds (see src/config.ts for defaults if unset)
PACE_MIN_EVENTS=10
PACE_WINDOW_MINUTES=180
PACE_MAX_GAP_MINUTES=4
PACE_NUDGE_COOLDOWN_MINUTES=240

# GitHub PR activity source (used by scripts/poll-github-and-nudge.ts).
# No GitHub token lives here — the scripts shell out to the already
# authenticated `gh` CLI, which manages its own credentials.
GITHUB_REPO=stanleyoz/slack-pace
GITHUB_USERNAME=stanleyoz

# Slack user id to attribute GitHub activity to and to run demo scripts
# against, so you don't need --user= on every command.
PACE_DEMO_USER_ID=
